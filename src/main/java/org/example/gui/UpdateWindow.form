<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.example.gui.UpdateWindow">
  <grid id="mainPanel" binding="mainPanel" layout-manager="GridLayoutManager" row-count="6" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="12" left="12" bottom="12" right="12"/>
    <constraints>
      <xy x="20" y="20" width="850" height="620"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="topPanel" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="8"/>
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="LB_Source" class="javax.swing.JLabel" binding="LB_Source">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Источник:"/>
            </properties>
          </component>
          <component id="CB_Source" class="javax.swing.JComboBox" binding="CB_Source">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="BT_Check" class="javax.swing.JButton" binding="BT_Check">
            <constraints>
              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
                <minimum-size width="140" height="32"/>
                <preferred-size width="140" height="32"/>
                <maximum-size width="140" height="48"/>
              </grid>
            </constraints>
            <properties>
              <text value="Проверить"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="scrollCheckResult">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <minimum-size width="-1" height="80"/>
            <preferred-size width="-1" height="130"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="TP_CheckResult" class="javax.swing.JTextPane" binding="TP_CheckResult">
            <constraints/>
            <properties>
              <editable value="false"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <vspacer id="spacer1">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
      </vspacer>
      <scrollpane id="scrollWhatsNews" binding="scrollWhatsNews" custom-create="true">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <minimum-size width="-1" height="200"/>
            <preferred-size width="-1" height="320"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="TP_WhatsNews" class="javax.swing.JTextPane" binding="TP_WhatsNews">
            <constraints/>
            <properties>
              <editable value="false"/>
            </properties>
          </component>
        </children>
      </scrollpane>
      <grid id="downloadPanel" layout-manager="GridLayoutManager" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="6" vgap="-1">
        <margin top="4" left="0" bottom="0" right="0"/>
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="BT_Download" class="javax.swing.JButton" binding="BT_Download">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false">
                <minimum-size width="140" height="32"/>
                <preferred-size width="140" height="32"/>
                <maximum-size width="140" height="48"/>
              </grid>
            </constraints>
            <properties>
              <text value="Скачать"/>
            </properties>
          </component>
          <component id="PB_Download" class="javax.swing.JProgressBar" binding="PB_Download">
            <constraints>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
        </children>
      </grid>
      <component id="TF_DownloadResult" class="javax.swing.JTextField" binding="TF_DownloadResult">
        <constraints>
          <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <minimum-size width="300" height="30"/>
          </grid>
        </constraints>
        <properties>
          <editable value="false"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
